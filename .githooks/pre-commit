#!/bin/bash
# Pre-commit hook for a PUBLIC repository.
#
# Primary concern: is this appropriate for public visibility?
# Everything committed here is visible to the entire internet.
#
# Install: git config core.hooksPath .githooks

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED" ]; then
  exit 0
fi

ISSUES=0

# ══════════════════════════════════════════════
# PUBLIC APPROPRIATENESS CHECK
# This is the most important check. Only these
# directories belong in the public repo:
#
#   sdks/         — Public SDKs for developers
#   beacons/      — Reference beacon implementations
#   scouts/       — Reference scout implementations
#   schemas/      — Protocol JSON schemas
#   examples/     — Example code
#   docs/         — Documentation
#   brand/        — Brand assets
#   fonts/        — Web fonts
#   portal/       — Developer portal
#   .github/      — CI, templates, governance
#   .githooks/    — Git hooks
#   *.html        — Website pages (root level)
#   *.png         — Logo images (root level)
#   *.md          — Root-level docs (README, etc.)
#
# Everything else needs explicit justification.
# ══════════════════════════════════════════════

ALLOWED_PATTERNS='^(sdks/|beacons/|scouts/|schemas/|examples/|docs/|brand/|fonts/|portal/|\.github/|\.githooks/)'
ALLOWED_ROOT='^[^/]*\.(html|png|md|json)$|^\.gitignore$|^CNAME$|^LICENSE$|^package\.json$'

NEW_FILES=$(echo "$STAGED" | grep -v -E "$ALLOWED_PATTERNS" | grep -v -E "$ALLOWED_ROOT" || true)

if [ -n "$NEW_FILES" ]; then
  echo -e "${RED}${BOLD}✗ PUBLIC REPO CHECK: Files outside allowed directories${NC}"
  echo -e "${RED}  This is a PUBLIC repository. The following files are not in${NC}"
  echo -e "${RED}  an approved public directory:${NC}"
  echo ""
  echo "$NEW_FILES" | while read -r f; do echo "    $f"; done
  echo ""
  echo -e "  ${YELLOW}Allowed directories: sdks/, beacons/, scouts/, schemas/,"
  echo -e "  examples/, docs/, brand/, fonts/, portal/, .github/, .githooks/${NC}"
  echo ""
  echo -e "  If this file genuinely belongs in the public repo, add its"
  echo -e "  path pattern to .githooks/pre-commit ALLOWED_PATTERNS."
  ISSUES=$((ISSUES + 1))
fi

# ── Prohibited file types ─────────────────────────────────
PROHIBITED=$(echo "$STAGED" | grep -iE '\.(pptx|docx|xlsx|pem|key|p12|pfx)$' || true)
ENV_FILES=$(echo "$STAGED" | grep -iE '\.env$' | grep -v '\.env\.example' | grep -v '\.env\.sample' || true)
PROHIBITED="$PROHIBITED$ENV_FILES"

if [ -n "$PROHIBITED" ]; then
  echo -e "${RED}✗ Prohibited file types:${NC}"
  echo "$PROHIBITED"
  ISSUES=$((ISSUES + 1))
fi

# ── Sensitive filename patterns ───────────────────────────
SENSITIVE=$(echo "$STAGED" | grep -iE '(investor|pitch.?deck|confidential|private|secret)' || true)
if [ -n "$SENSITIVE" ]; then
  echo -e "${RED}✗ Potentially sensitive filenames:${NC}"
  echo "$SENSITIVE"
  ISSUES=$((ISSUES + 1))
fi

# ── Secret patterns in file contents ──────────────────────
SECRETS_FOUND=0

for FILE in $STAGED; do
  # Skip CI/hook config (they contain detection patterns, not real secrets)
  if echo "$FILE" | grep -qE '^\.github/|^\.githooks/'; then
    continue
  fi
  # Only scan text files
  if echo "$FILE" | grep -qE '\.(js|ts|json|md|html|yml|yaml|sh|py|env)$'; then
    CONTENT=$(git show ":$FILE" 2>/dev/null || true)

    # Live API keys
    if echo "$CONTENT" | grep -qE '(sk_live_|pk_live_|AKIA[0-9A-Z]{16})'; then
      echo -e "${RED}✗ Potential live API key in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi

    # Private keys
    if echo "$CONTENT" | grep -qE 'BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'; then
      echo -e "${RED}✗ Private key material in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi

    # Connection strings with passwords
    if echo "$CONTENT" | grep -qE '(mongodb|postgres|mysql|redis)://[^:]+:[^@]{8,}@'; then
      echo -e "${RED}✗ Database connection string with password in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi
  fi
done

if [ "$SECRETS_FOUND" -gt 0 ]; then
  ISSUES=$((ISSUES + SECRETS_FOUND))
fi

# ── Documentation reminder (warning only) ─────────────────
CODE_CHANGED=$(echo "$STAGED" | grep -E '^(sdks|beacons|scouts|schemas)/' || true)
DOC_CHANGED=$(echo "$STAGED" | grep -E '^(docs/|.*README\.md$|CHANGELOG\.md)' || true)

if [ -n "$CODE_CHANGED" ] && [ -z "$DOC_CHANGED" ]; then
  echo -e "${YELLOW}⚠ Code changed without documentation updates.${NC}"
  echo "  Consider updating docs/ or a README.md."
fi

# ── Result ────────────────────────────────────────────────
if [ "$ISSUES" -gt 0 ]; then
  echo ""
  echo -e "${RED}${BOLD}Commit blocked — $ISSUES issue(s) found.${NC}"
  echo -e "This is a ${BOLD}public${NC} repository. Everything committed is visible to everyone."
  echo "Use --no-verify to bypass (not recommended)."
  exit 1
fi

echo -e "${GREEN}✓ All checks passed — safe for public repo.${NC}"
exit 0
