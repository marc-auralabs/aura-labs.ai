#!/bin/bash
# Pre-commit hook for a PRIVATE repository.
#
# Primary concern: no secrets, no prohibited file types.
# Directory allowlisting removed — repo is private (DEC-015).
#
# Install: git config core.hooksPath .githooks

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED" ]; then
  exit 0
fi

ISSUES=0

# ── Prohibited file types ─────────────────────────────────
PROHIBITED=$(echo "$STAGED" | grep -iE '\.(pptx|docx|xlsx|pem|key|p12|pfx)$' || true)
ENV_FILES=$(echo "$STAGED" | grep -iE '\.env$' | grep -v '\.env\.example' | grep -v '\.env\.sample' || true)
PROHIBITED="$PROHIBITED$ENV_FILES"

if [ -n "$PROHIBITED" ]; then
  echo -e "${RED}✗ Prohibited file types:${NC}"
  echo "$PROHIBITED"
  ISSUES=$((ISSUES + 1))
fi

# ── Sensitive filename patterns ───────────────────────────
SENSITIVE=$(echo "$STAGED" | grep -iE '(investor|pitch.?deck|confidential|private|secret)' || true)
if [ -n "$SENSITIVE" ]; then
  echo -e "${RED}✗ Potentially sensitive filenames:${NC}"
  echo "$SENSITIVE"
  ISSUES=$((ISSUES + 1))
fi

# ── Secret patterns in file contents ──────────────────────
SECRETS_FOUND=0

for FILE in $STAGED; do
  # Skip CI/hook config (they contain detection patterns, not real secrets)
  if echo "$FILE" | grep -qE '^\.github/|^\.githooks/'; then
    continue
  fi
  # Only scan text files
  if echo "$FILE" | grep -qE '\.(js|ts|json|md|html|yml|yaml|sh|py|env)$'; then
    CONTENT=$(git show ":$FILE" 2>/dev/null || true)

    # Live API keys
    if echo "$CONTENT" | grep -qE '(sk_live_|pk_live_|AKIA[0-9A-Z]{16})'; then
      echo -e "${RED}✗ Potential live API key in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi

    # Private keys
    if echo "$CONTENT" | grep -qE 'BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'; then
      echo -e "${RED}✗ Private key material in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi

    # Connection strings with passwords
    if echo "$CONTENT" | grep -qE '(mongodb|postgres|mysql|redis)://[^:]+:[^@]{8,}@'; then
      echo -e "${RED}✗ Database connection string with password in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi
  fi
done

if [ "$SECRETS_FOUND" -gt 0 ]; then
  ISSUES=$((ISSUES + SECRETS_FOUND))
fi

# ── Documentation propagation check ───────────────────────
# Source code changes should include corresponding doc updates.
# This is a WARNING for most changes and a BLOCK for high-impact files.

SOURCE_CHANGED=$(echo "$STAGED" | grep -E '^(aura-core/|sdks/|examples/agents/|mock/|apps/)' | grep -v 'node_modules' | grep -v '\.test\.' || true)
DOC_CHANGED=$(echo "$STAGED" | grep -E '^(docs/|portal/|.*README\.md$|CHANGELOG\.md)' || true)

if [ -n "$SOURCE_CHANGED" ]; then
  # Check for high-impact file changes that MUST have doc updates
  API_CHANGED=$(echo "$STAGED" | grep -E 'aura-core/services/core-api/src/index\.js$' || true)
  SCHEMA_CHANGED=$(echo "$STAGED" | grep -E 'aura-core/database/schema\.sql$' || true)
  AUTH_CHANGED=$(echo "$STAGED" | grep -E 'agent-auth\.js$' || true)
  SDK_CHANGED=$(echo "$STAGED" | grep -E '^sdks/.*src/' || true)
  HIGH_IMPACT="$API_CHANGED$SCHEMA_CHANGED$AUTH_CHANGED$SDK_CHANGED"

  if [ -n "$HIGH_IMPACT" ] && [ -z "$DOC_CHANGED" ]; then
    echo -e "${RED}${BOLD}✗ High-impact source changed without documentation updates${NC}"
    echo -e "  Modified:"
    echo "$HIGH_IMPACT" | while read -r f; do echo "    $f"; done
    echo ""
    echo -e "  ${YELLOW}These files affect the public API, auth model, or SDK interface."
    echo -e "  Update the corresponding docs (see Documentation Manifest in senior-engineer skill)."
    echo -e "  At minimum: docs/api/README.md, relevant SDK README, or docs/architecture/flows.html${NC}"
    echo ""
    echo -e "  Use --no-verify to bypass if this is an internal-only change."
    ISSUES=$((ISSUES + 1))
  elif [ -n "$SOURCE_CHANGED" ] && [ -z "$DOC_CHANGED" ]; then
    echo -e "${YELLOW}⚠ Source code changed without documentation updates.${NC}"
    echo "  Review the Documentation Manifest — does this change affect external docs?"
  fi
fi

# ── Result ────────────────────────────────────────────────
if [ "$ISSUES" -gt 0 ]; then
  echo ""
  echo -e "${RED}${BOLD}Commit blocked — $ISSUES issue(s) found.${NC}"
  echo "Use --no-verify to bypass (not recommended)."
  exit 1
fi

echo -e "${GREEN}✓ All checks passed.${NC}"
exit 0
