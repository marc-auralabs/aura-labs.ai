#!/bin/bash
# Pre-commit hook: catches secrets, prohibited files, and missing docs
# Install: git config core.hooksPath .githooks

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
NC='\033[0m'

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED" ]; then
  exit 0
fi

ISSUES=0

# ── 1. Prohibited file types ──────────────────────────────
PROHIBITED=$(echo "$STAGED" | grep -iE '\.(pptx|docx|xlsx)$' || true)
ENV_FILES=$(echo "$STAGED" | grep -iE '\.env$' | grep -v '\.env\.example' | grep -v '\.env\.sample' || true)
PROHIBITED="$PROHIBITED$ENV_FILES"

if [ -n "$PROHIBITED" ]; then
  echo -e "${RED}✗ Prohibited file types staged for commit:${NC}"
  echo "$PROHIBITED"
  echo "  These file types should not be in a public repo."
  echo "  Remove with: git reset HEAD <file>"
  ISSUES=$((ISSUES + 1))
fi

# ── 2. Sensitive filename patterns ────────────────────────
SENSITIVE=$(echo "$STAGED" | grep -iE '(investor|pitch.?deck|confidential|private|secret)' || true)
if [ -n "$SENSITIVE" ]; then
  echo -e "${RED}✗ Potentially sensitive files staged:${NC}"
  echo "$SENSITIVE"
  ISSUES=$((ISSUES + 1))
fi

# ── 3. Secret patterns in staged file contents ────────────
SECRETS_FOUND=0

for FILE in $STAGED; do
  # Skip CI/hook config (they contain detection patterns, not real secrets)
  if echo "$FILE" | grep -qE '^\.github/|^\.githooks/'; then
    continue
  fi
  # Only scan text files
  if echo "$FILE" | grep -qE '\.(js|ts|json|md|html|yml|yaml|sh|py|env)$'; then
    CONTENT=$(git show ":$FILE" 2>/dev/null || true)

    # Live API keys
    if echo "$CONTENT" | grep -qE '(sk_live_|pk_live_|AKIA[0-9A-Z]{16})'; then
      echo -e "${RED}✗ Potential live API key in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi

    # Private keys
    if echo "$CONTENT" | grep -qE 'BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'; then
      echo -e "${RED}✗ Private key material in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi

    # Connection strings with passwords
    if echo "$CONTENT" | grep -qE '(mongodb|postgres|mysql|redis)://[^:]+:[^@]{8,}@'; then
      echo -e "${RED}✗ Database connection string with password in: $FILE${NC}"
      SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi
  fi
done

if [ "$SECRETS_FOUND" -gt 0 ]; then
  ISSUES=$((ISSUES + SECRETS_FOUND))
fi

# ── 4. Documentation reminder (warning only) ─────────────
CODE_CHANGED=$(echo "$STAGED" | grep -E '^(aura-core|sdks|beacons|scouts|schemas|core)/' || true)
DOC_CHANGED=$(echo "$STAGED" | grep -E '^(docs/|.*README\.md$|CHANGELOG\.md)' || true)

if [ -n "$CODE_CHANGED" ] && [ -z "$DOC_CHANGED" ]; then
  echo -e "${YELLOW}⚠ Code changed without documentation updates:${NC}"
  echo "$CODE_CHANGED" | head -5
  echo "  Consider updating docs/ or a README.md."
  echo "  Add [skip-docs] to your commit message if not needed."
  # Warning only locally — CI will enforce on PRs.
fi

# ── Result ────────────────────────────────────────────────
if [ "$ISSUES" -gt 0 ]; then
  echo ""
  echo -e "${RED}Commit blocked: $ISSUES issue(s) found.${NC}"
  echo "Fix the issues above, or use --no-verify to bypass (not recommended)."
  exit 1
fi

echo -e "${GREEN}✓ Pre-commit checks passed.${NC}"
exit 0
